# Fireworks AI (remote/escalation tier)
LOCAL_BACKEND=mlx
LOCAL_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
MAX_NEW_TOKENS=48
MOCK_LOCAL_MODEL=0
MOCK_REMOTE_CLIENT=1
FIREWORKS_API_KEY=AQ.Ab8RN6I-Kjl4_sjxpwblOPnbz4ZfG7cEDvBCVUu04qpRaxPvhQ
FIREWORKS_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
FIREWORKS_MODEL=gemini-2.5-flash
# FIREWORKS_MODEL

# Local tier — bootstrap default, swap to a Gemma 4 variant once AMD
# Developer Cloud credits land (also unlocks the "Best Use of Gemma"
# bonus pool at no extra build cost).
LOCAL_MODEL=Qwen/Qwen2.5-0.5B-Instruct
MAX_NEW_TOKENS=256

# Routing thresholds — placeholders. Calibrate against a labeled set
# (task, is the local answer actually correct) before submission.
MEAN_LOGPROB_THRESHOLD=-0.5
MIN_LOGPROB_THRESHOLD=-2.0

# Testing toggles — set both to 1 to run the whole loop with zero
# network calls and zero model downloads.
MOCK_LOCAL_MODEL=0
MOCK_REMOTE_CLIENT=0